# =============================================================================
# MediChain Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control. Use Docker secrets
# or a secrets manager in production.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# Active Spring profile: dev | prod | test
SPRING_PROFILES_ACTIVE=prod

# ---------------------------------------------------------------------------
# PostgreSQL Database
# ---------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/medichain
SPRING_DATASOURCE_USERNAME=medichain
# WARNING: Change this immediately in production. Use Docker secrets or a vault.
SPRING_DATASOURCE_PASSWORD=changeme_in_production

# ---------------------------------------------------------------------------
# Redis (caching & session store)
# ---------------------------------------------------------------------------
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Apache Kafka (event streaming)
# ---------------------------------------------------------------------------
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
# Consumer group ID
SPRING_KAFKA_CONSUMER_GROUP_ID=medichain-group

# ---------------------------------------------------------------------------
# JSON Web Token (JWT) — Authentication
# ---------------------------------------------------------------------------
# Generate a secure random key: openssl rand -base64 64
# Minimum 256-bit (32 chars) for HS256; 512-bit (64 chars) recommended
MEDICHAIN_JWT_SECRET=changeme_generate_a_random_64_char_secret_using_openssl_rand_base64_64
MEDICHAIN_JWT_EXPIRATION_MS=86400000

# ---------------------------------------------------------------------------
# Claude AI API — Demand Forecasting
# ---------------------------------------------------------------------------
# Get your API key from https://console.anthropic.com
MEDICHAIN_AI_CLAUDE_API_KEY=
MEDICHAIN_AI_CLAUDE_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# Email (SMTP) — Alert Notifications
# ---------------------------------------------------------------------------
# Use app passwords for Gmail; or your corporate SMTP relay
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# ---------------------------------------------------------------------------
# MediChain Specific
# ---------------------------------------------------------------------------
# Database password (used by docker-compose for the postgres service)
MEDICHAIN_DB_PASSWORD=${SPRING_DATASOURCE_PASSWORD:-changeme_in_production}

# Enable/disable demo data seeding on startup
MEDICHAIN_SEED_DEMO_DATA=false

# ---------------------------------------------------------------------------
# Docker Secrets (alternative to env vars in production)
# ---------------------------------------------------------------------------
# Instead of env vars above, mount Docker secrets and reference them here:
#   /run/secrets/medichain_db_password
#   /run/secrets/medichain_jwt_secret
#   /run/secrets/medichain_claude_api_key
#
# The Spring Boot app reads secrets from these file paths when configured.
# ---------------------------------------------------------------------------
