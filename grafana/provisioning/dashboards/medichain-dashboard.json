      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "days_until_expiry{application=\"medichain\"}",
          "legendFormat": "{{drug_name}} [{{batch_number}}]",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Expiry Timeline (Days Until Expiry per Batch)",
      "type": "timeseries"
    },
